# Create a .env.local file with your Sanity project details
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity read token — required once the dataset ACL is set to Private
# Generate at: https://www.sanity.io/manage → API → Tokens → Add API Token (Viewer role)
# When this is set, the dataset can be flipped to Private in
# Sanity → API → Datasets so unauthenticated GROQ is blocked.
SANITY_API_READ_TOKEN=your_read_token_here

# Sanity write token — required for assessment submissions
# Generate at: https://www.sanity.io/manage → API → Tokens → Add API Token (Editor role)
SANITY_WRITE_TOKEN=your_write_token_here

# Resend API key — for contact form and assessment email delivery
RESEND_API_KEY=your_resend_api_key_here

# Email sender address — set after verifying your domain in Resend
# Uses Resend sandbox sender by default (for development)
# EMAIL_FROM=ECM.DEV <contact@ecm.dev>

# CRM webhook URL — optional, enables webhook-based CRM sync
# When not set, CRM events are logged to console
# CRM_WEBHOOK_URL=https://your-crm-webhook-endpoint.com/api/webhook

# CSRF secret — required for form protection (contact + assessment endpoints).
# Must be at least 32 characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
CSRF_SECRET=your_csrf_secret_here_min_32_chars

# Public site URL — used for email links and absolute URLs
# NEXT_PUBLIC_SITE_URL=https://ecm.dev

# Localisation Cost Estimator — booking URL used by the primary CTA.
# Browser-accessible, hence NEXT_PUBLIC_ prefix.
# NEXT_PUBLIC_CAL_BOOKING_URL=https://cal.com/ecm-dev/estimator-review
